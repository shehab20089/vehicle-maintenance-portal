        <dc:Bounds x="1190" y="293" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_maintenance_officer_processing_di" bpmnElement="task_maintenance_officer_processing">
        <dc:Bounds x="1300" y="278" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_maint_officer_decision_di" bpmnElement="gw_maint_officer_decision" isMarkerVisible="true">
        <dc:Bounds x="1480" y="293" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_specialist_processing_di" bpmnElement="task_specialist_processing">
        <dc:Bounds x="1300" y="430" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_specialist_decision_di" bpmnElement="gw_specialist_decision" isMarkerVisible="true">
        <dc:Bounds x="1480" y="445" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_maintenance_outcome_di" bpmnElement="task_maintenance_outcome">
        <dc:Bounds x="1590" y="278" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_generate_maintenance_report_di" bpmnElement="task_generate_maintenance_report">
        <dc:Bounds x="1770" y="278" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_final_approval_di" bpmnElement="task_final_approval">
        <dc:Bounds x="1950" y="278" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_final_approval_decision_di" bpmnElement="gw_final_approval_decision" isMarkerVisible="true">
        <dc:Bounds x="2130" y="293" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_generate_final_report_di" bpmnElement="task_generate_final_report">
        <dc:Bounds x="2240" y="278" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_close_request_di" bpmnElement="task_close_request">
        <dc:Bounds x="2420" y="278" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_completed_di" bpmnElement="end_completed">
        <dc:Bounds x="2600" y="300" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_rejected_di" bpmnElement="end_rejected">
        <dc:Bounds x="1590" y="150" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="flow_start_to_submit_di" bpmnElement="flow_start_to_submit">
        <di:waypoint x="196" y="318" />
        <di:waypoint x="250" y="318" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_submit_to_initial_review_di" bpmnElement="flow_submit_to_initial_review">
        <di:waypoint x="370" y="318" />
        <di:waypoint x="430" y="318" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_initial_review_to_gw_di" bpmnElement="flow_initial_review_to_gw">
        <di:waypoint x="550" y="318" />
        <di:waypoint x="610" y="318" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_initial_approve_di" bpmnElement="flow_initial_approve">
        <di:waypoint x="660" y="318" />
        <di:waypoint x="720" y="318" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_initial_reject_to_end_di" bpmnElement="flow_initial_reject_to_end">
        <di:waypoint x="635" y="293" />
        <di:waypoint x="635" y="168" />
        <di:waypoint x="1590" y="168" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_supply_review_to_gw_di" bpmnElement="flow_supply_review_to_gw">
        <di:waypoint x="840" y="318" />
        <di:waypoint x="900" y="318" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_supply_approve_di" bpmnElement="flow_supply_approve">
        <di:waypoint x="950" y="318" />
        <di:waypoint x="1010" y="318" />
